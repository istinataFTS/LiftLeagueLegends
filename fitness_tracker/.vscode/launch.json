{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run (production backend)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define=ENVIRONMENT=development"
      ]
    },
    {
      "name": "Run (production backend + debug logs)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define=ENVIRONMENT=development",
        "--dart-define=ENABLE_DEBUG_LOGS=true"
      ]
    },
    {
      "name": "Run (custom backend — copy dart_defines.example.json to dart_defines.json first)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define-from-file=dart_defines.json"
      ]
    },
    {
      "name": "Run (staging — same Supabase project, ENVIRONMENT=staging)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define=ENVIRONMENT=staging",
        "--dart-define=ENABLE_SUPABASE=true",
        "--dart-define=SUPABASE_URL=https://liftleaguelegends.com",
